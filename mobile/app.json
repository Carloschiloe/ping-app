{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Ping necesita acceso a tu cámara para las videollamadas.",
        "NSMicrophoneUsageDescription": "Ping necesita acceso a tu micrófono para las llamadas."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Ping necesita FaceID para proteger la privacidad de tus chats y recordatorios."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Ping necesita acceso a tu cámara para las videollamadas.",
          "microphonePermission": "Ping necesita acceso a tu micrófono para las llamadas."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0baf032d-de1a-49e7-9181-a5897927fb11"
      }
    },
    "owner": "carloschiloe"
  }
}